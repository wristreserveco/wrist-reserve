# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Service role key (webhooks, chat history API). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — required in production (checkout redirects, emails, webhooks).
# Use your real domain, e.g. https://wristreserve.com (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Payments — you only need to configure the rails you want to use.
# -----------------------------------------------------------------------------

# Stripe (cards / Apple Pay / Google Pay / Link). ONLY enable for legit inventory.
# Do NOT run 1:1 / replica products through Stripe — your account will be
# terminated and funds held for 90+ days. Leave blank to hide the card option.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# NOWPayments — crypto (BTC, ETH, USDT-TRC20, USDC, LTC, ~60+ coins).
# Sign up: https://nowpayments.io  — Settings → API Keys
# Free, non-custodial, auto-conversion to your preferred payout currency.
# IPN secret: Settings → IPN → generate and paste the same value here.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Manual payment instructions shown to buyers who choose Zelle / Cash App / wire.
# Admins also see these in the dashboard. Leave blank to hide a method.
PAYMENT_ZELLE_HANDLE=
PAYMENT_CASHAPP_HANDLE=
PAYMENT_APPLECASH_HANDLE=
PAYMENT_WIRE_INSTRUCTIONS=
# Comma-separated list to show in the UI, e.g. "zelle,cashapp,wire"
NEXT_PUBLIC_MANUAL_PAYMENT_METHODS=zelle,cashapp,wire

# Optional static QR images shown on the checkout instructions screen.
# Cash App: leave blank — QR auto-generated from the amount + handle.
# Zelle: most banks generate their own Zelle QR. Screenshot it from your
#        banking app, upload to /public/zelle-qr.png (or Supabase Storage)
#        and paste the URL here (e.g. /zelle-qr.png).
NEXT_PUBLIC_PAYMENT_ZELLE_QR_URL=
NEXT_PUBLIC_PAYMENT_CASHAPP_QR_URL=

# Optional: Telegram admin notifications (off by default — admin dashboard now
# has in-app realtime alerts with sound). Leave blank unless you want phone
# pushes in addition to the dashboard toast + badge.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
